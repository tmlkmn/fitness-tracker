# ── Core ────────────────────────────────────────────────────────────────
DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (Mailjet) ─────────────────────────────────────────────────────
MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=
EMAIL_FROM_ADDRESS=noreply@fitmusc.com
EMAIL_FROM_NAME=FitMusc

# ── Web push (VAPID) ────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Cron ────────────────────────────────────────────────────────────────
CRON_SECRET=

# ── AI (Anthropic) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Feature flags ───────────────────────────────────────────────────────
# When "true": opens public /kayit signup + 14-day trial and indexes
# /fiyatlandirma. Leave unset/false to keep the app invite-only.
FEATURE_PUBLIC_SIGNUP=false

# ── Billing: company identity (Lemon Squeezy store approval + anti-spam) ─
COMPANY_LEGAL_NAME=
COMPANY_ADDRESS=
COMPANY_TAX_ID=

# ── Billing: Lemon Squeezy (global / USD) ───────────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
# Webhook secret. _PREVIOUS is optional and only used during rotation.
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_WEBHOOK_SECRET_PREVIOUS=
# Variant IDs — one per tier+interval, created in the LS dashboard.
LS_PRO_MONTHLY_VARIANT_ID=
LS_PRO_YEARLY_VARIANT_ID=
LS_ELITE_MONTHLY_VARIANT_ID=
LS_ELITE_YEARLY_VARIANT_ID=

# ── Billing: iyzico (Turkey / TRY) — wired up in Sprint 3 ───────────────
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_WEBHOOK_SECRET=
IYZICO_WEBHOOK_SECRET_PREVIOUS=
IYZICO_PRO_MONTHLY_REF=
IYZICO_PRO_YEARLY_REF=
IYZICO_ELITE_MONTHLY_REF=
IYZICO_ELITE_YEARLY_REF=
# 32-byte hex key for AES-256-GCM encryption of iyzico identity numbers (TCKN).
BILLING_ENCRYPTION_KEY=
